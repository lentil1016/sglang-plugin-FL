# CI image for sglang-plugin-FL on Moore Threads MUSA GPU
# Base: mthreads/musa (official Moore Threads MUSA SDK image from Docker Hub)
#
# Build:
#   docker build -t sglang-plugin-fl:latest-musa-ci \
#     -f container/musa/containerfile .
#
# Push target: harbor.baai.ac.cn/flagos-dev/sglang-plugin-fl:latest-musa-ci
#
# NOTE: Verify the BASE_IMAGE tag matches your MUSA SDK version.
#       Check: https://hub.docker.com/r/mthreads/musa/tags

ARG BASE_IMAGE=mthreads/musa
ARG BASE_IMAGE_VERSION=rc4.3.6-devel-ubuntu22.04

FROM ${BASE_IMAGE}:${BASE_IMAGE_VERSION} AS base

ARG SGLANG_VERSION=0.4.7
ARG FLAGGEMS_VERSION=v5.0.0
ARG PYTHON_VERSION=3.10

ENV DEBIAN_FRONTEND=noninteractive
ENV MUSA_HOME=/usr/local/musa \
    MTHREADS_VISIBLE_DEVICES=all
ENV PATH="${MUSA_HOME}/bin:${PATH}" \
    LD_LIBRARY_PATH="${MUSA_HOME}/lib:${LD_LIBRARY_PATH}"

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
        wget \
        vim \
        cmake \
        ninja-build \
        libnuma-dev \
        numactl \
        libgfortran5 \
        libopenmpi-dev \
        openmpi-bin \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Install torch and torch_musa (from FlagOS PyPI)
ARG MUSA_TORCH_VERSION=2.9.0+musa.4.3.6
ARG TORCH_MUSA_VERSION=2.9.0
RUN pip install --no-cache-dir \
        "torch==${MUSA_TORCH_VERSION}" \
        "torch_musa==${TORCH_MUSA_VERSION}" \
        --index-url https://resource.flagos.net/repository/flagos-pypi-mthreads/simple \
        --trusted-host resource.flagos.net

WORKDIR /workspace

# ---------- ci stage ----------
FROM base AS ci

ARG SGLANG_VERSION=0.4.7
ARG FLAGGEMS_VERSION=v5.0.0

# Install sglang runtime (avoid pulling cuda-specific deps)
RUN VLLM_TARGET_DEVICE="empty" pip install --no-cache-dir \
        "sglang[runtime]==${SGLANG_VERSION}" \
        --extra-index-url https://download.pytorch.org/whl/cpu/ && \
    pip uninstall -y triton 2>/dev/null || true && \
    pip cache purge

# Install triton for MUSA
RUN pip install --no-cache-dir "triton==3.6.0+git89458660" \
        --index-url https://resource.flagos.net/repository/flagos-pypi-mthreads/simple \
        --trusted-host resource.flagos.net \
    || echo "WARN: triton-musa not found, skipping"

# Install FlagGems (MUSA backend)
RUN pip install --no-cache-dir -U scikit-build-core==0.11 pybind11 && \
    git clone --branch ${FLAGGEMS_VERSION} --depth 1 \
        https://github.com/flagos-ai/FlagGems /tmp/FlagGems && \
    pip install --no-build-isolation \
        --config-settings=cmake.define.FLAGGEMS_BACKEND=MUSA \
        /tmp/FlagGems && \
    rm -rf /tmp/FlagGems

# Test and dev tools
RUN pip install --no-cache-dir \
        pytest \
        pytest-cov \
        pytest-timeout \
        pytest-json-report \
        pytest-metadata \
        numpy \
        requests \
        ruff \
        pyyaml

WORKDIR /workspace
